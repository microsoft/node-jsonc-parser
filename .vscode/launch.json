{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Unit Tests",
			"type": "node",
			"request": "launch",
			"stopOnEntry": false,
			"cwd": "${workspaceRoot}",
			"runtimeExecutable": null,
			"runtimeArgs": [
				"--enable-source-maps",
				"--test",
				"./lib/umd/test/**/*.test.js"
			],
			"env": {},
			"sourceMaps": true,
			"outFiles": ["${workspaceRoot}/lib/umd/**/*.js"],
			"preLaunchTask": "npm: watch"
		}
	]
}